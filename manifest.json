{
  "manifest_version": 3,
  "name": "Hugola Unblock",
  "version": "5.0.0",
  "description": "Türkiye'de engellenen YouTube kanallarını VPN'siz görüntüle",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://m.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "hugola_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hugola-unblock@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": false,
        "data_collected": false
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
